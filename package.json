{
  "name": "forest-nursery-management",
  "version": "1.0.0",
  "description": "国有林场苗圃物资管理系统",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.2.5",
    "element-plus": "^2.4.4",
    "@element-plus/icons-vue": "^2.3.1",
    "pinia": "^2.1.7",
    "dayjs": "^1.11.10",
    "localforage": "^1.10.0",
    "echarts": "^5.4.3",
    "vue-echarts": "^6.6.8",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "vite": "^5.0.8",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.forest.nursery",
    "productName": "林场苗圃管理系统",
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    }
  }
}
